# NutriMCP — Environment Configuration Sample
# Copy this file to .env and fill in your values.

# SQLite database path (relative to project root)
DATABASE_URL=sqlite:///./db/nutrition.db

# Set to False in production
DEBUG=True

# Default API key seeded into the database on first run
DEFAULT_AUTH_TOKEN=default-key-aCW5eV_VAL20k9MToEUOoFHQ2_DIXu80GxJYIkPSAIc

# Severity threshold: auto-book doctor if complaint severity >= this value (1-10)
SEVERITY_ALERT_THRESHOLD=7

# Run seed.py on container startup (true/false)
SEED_ENABLED=true
